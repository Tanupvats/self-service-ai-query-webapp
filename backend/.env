# --- Ollama Connection ---
# The local URL where your Ollama server is running
OLLAMA_BASE_URL=http://localhost:11434

# --- LLM Settings ---
# The main model used for ambiguity checking, clarifying, and writing SQL
LLM_MODEL=llama3
# Keeps the model deterministic for code generation (0.0 is recommended for SQL)
LLM_TEMPERATURE=0.0

# --- Embeddings Settings ---
# The model used to embed the SQL examples into the VectorDB
EMBEDDING_MODEL=nomic-embed-text

# --- Vector Database ---
# The local path where ChromaDB will store its vectors
DB_DIR=./chroma_db